# -------------------------------------------
# ZFlow Backend - Environment Variables
# -------------------------------------------
# Copy this file to .env and fill in the values

# Server
PORT=7563
NODE_ENV=production
FRONTEND_URL=https://crm.ideva.ai
BACKEND_URL=https://crm.ideva.ai

# Database (PostgreSQL)
POSTGRES_HOST=postgres
POSTGRES_USER=zflow
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=zflow
DB_PORT=5432
DB_SSL=false
DB_LOGGING=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication (REQUIRED - generate with: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64

# Meta / WhatsApp Business API
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_32
META_CONFIG_ID=your_meta_config_id

# Migrations & Seeds (set to "true" on first run)
RUN_MIGRATIONS=true
RUN_SEEDS=true

# Logging
LOG_LEVEL=info

# Limits
USER_LIMIT=50
CONNECTIONS_LIMIT=10
